pragma solidity ^0.8.20;

import "@openzeppelin/contracts/governance/Governor.sol";
import "@openzeppelin/contracts/governance/extensions/GovernorCountingSimple.sol";
import "@openzeppelin/contracts/governance/extensions/GovernorVotes.sol";
import "@openzeppelin/contracts/governance/extensions/GovernorTimelockControl.sol";
import "@openzeppelin/contracts/governance/extensions/GovernorSettings.sol";

contract AFRCGovernor is 
    Governor, 
    GovernorCountingSimple, 
    GovernorVotes, 
    GovernorTimelockControl, 
    GovernorSettings 
{
    uint256 public constant LEVEL_1 = 1;
    uint256 public constant LEVEL_2 = 2;
    uint256 public constant LEVEL_3 = 3;
    uint256 public constant LEVEL_4 = 4;

    mapping(uint256 => uint256) public proposalLevel;
    uint256 public constant MAX_VOTING_POWER_BPS = 1000;

    event ProposalLevelSet(uint256 indexed proposalId, uint256 level);

    constructor(
        IVotes _token,
        TimelockController _timelock,
        uint256 _initialVotingDelay,
        uint256 _initialVotingPeriod,
        uint256 _initialProposalThreshold
    )
        Governor("AFRC Governor")
        GovernorSettings(_initialVotingDelay, _initialVotingPeriod, _initialProposalThreshold)
        GovernorVotes(_token)
        GovernorTimelockControl(_timelock)
    {}

    function propose(
        address[] memory targets,
        uint256[] memory values,
        bytes[] memory calldatas,
        string memory description,
        uint256 level
    ) public virtual returns (uint256) {
        require(level >= LEVEL_1 && level <= LEVEL_4, "AFRCGovernor: invalid level");
        uint256 proposalId = super.propose(targets, values, calldatas, description);
        proposalLevel[proposalId] = level;
        emit ProposalLevelSet(proposalId, level);
        return proposalId;
    }

    function quorum(uint256 blockNumber) public view override returns (uint256) {
        return (token.getPastTotalSupply(blockNumber) * 15) / 100;
    }

    function getQuorumForLevel(uint256 level) public pure returns (uint256 percentage) {
        if (level == LEVEL_1) return 15;
        if (level == LEVEL_2) return 20;
        if (level == LEVEL_3) return 30;
        if (level == LEVEL_4) return 40;
        revert("AFRCGovernor: invalid level");
    }

    function _getVotes(
        address account,
        uint256 blockNumber,
        bytes memory /* params */
    ) internal view override(Governor, GovernorVotes) returns (uint256) {
        uint256 rawVotes = token.getPastVotes(account, blockNumber);
        uint256 totalSupply = token.getPastTotalSupply(blockNumber);
        uint256 maxVotes = (totalSupply * MAX_VOTING_POWER_BPS) / 10000;
        if (rawVotes > maxVotes) return maxVotes;
        return rawVotes;
    }

    function votingDelay() public view override(Governor, GovernorSettings) returns (uint256) {
        return super.votingDelay();
    }

    function votingPeriod() public view override(Governor, GovernorSettings) returns (uint256) {
        return super.votingPeriod();
    }

    function proposalThreshold() public view override(Governor, GovernorSettings) returns (uint256) {
        return super.proposalThreshold();
    }

    function state(uint256 proposalId) public view override(Governor, GovernorTimelockControl) returns (ProposalState) {
        return super.state(proposalId);
    }

    function _queueOperations(
        uint256 proposalId,
        address[] memory targets,
        uint256[] memory values,
        bytes[] memory calldatas,
        bytes32 descriptionHash
    ) internal override(Governor, GovernorTimelockControl) returns (uint48) {
        return super._queueOperations(proposalId, targets, values, calldatas, descriptionHash);
    }

    function _executeOperations(
        uint256 proposalId,
        address[] memory targets,
        uint256[] memory values,
        bytes[] memory calldatas,
        bytes32 descriptionHash
    ) internal override(Governor, GovernorTimelockControl) {
        super._executeOperations(proposalId, targets, values, calldatas, descriptionHash);
    }

    function _cancel(
        address[] memory targets,
        uint256[] memory values,
        bytes[] memory calldatas,
        bytes32 descriptionHash
    ) internal override(Governor, GovernorTimelockControl) returns (uint256) {
        return super._cancel(targets, values, calldatas, descriptionHash);
    }

    function _executor() internal view override(Governor, GovernorTimelockControl) returns (address) {
        return super._executor();
    }

    function supportsInterface(bytes4 interfaceId) public view override(Governor, GovernorTimelockControl) returns (bool) {
        return super.supportsInterface(interfaceId);
    }
}